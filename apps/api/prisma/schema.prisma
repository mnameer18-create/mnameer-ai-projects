generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  role                Role
  status              UserStatus @default(ACTIVE)
  refreshTokenHash    String?
  createdAt           DateTime @default(now())
  employee            Employee?
  auditActions        AuditLog[] @relation("auditActor")
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
}

model Employee {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id])
  fullName          String
  phone             String?
  address           String?
  departmentId      String?
  department        Department?     @relation(fields: [departmentId], references: [id])
  title             String?
  joinDate          DateTime?
  emergencyContact  String?
  bankInfoEncrypted String?
  createdAt         DateTime        @default(now())
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  attendanceLogs    AttendanceLog[]
  salaryProfiles    SalaryProfile[]
  documents         Document[]
}

model LeavePolicy {
  id               String         @id @default(cuid())
  name             String
  annualDays       Int
  carryForwardDays Int
  balances         LeaveBalance[]
  requests         LeaveRequest[]
}

model LeaveBalance {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  policyId    String
  policy      LeavePolicy @relation(fields: [policyId], references: [id])
  year        Int
  remainingDays Float
  @@unique([employeeId, policyId, year])
}

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  policyId    String
  policy      LeavePolicy @relation(fields: [policyId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String
  status      LeaveStatus @default(PENDING)
  approverId  String?
  approver    User?       @relation(fields: [approverId], references: [id])
  createdAt   DateTime    @default(now())
}

model AttendanceLog {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        DateTime
  clockInAt   DateTime?
  clockOutAt  DateTime?
  notes       String?
  @@unique([employeeId, date])
}

model SalaryProfile {
  id             String   @id @default(cuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  baseSalary     Float
  allowancesJson Json
  deductionsJson Json
  effectiveFrom  DateTime
}

model Document {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  type        String
  filePath    String
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("auditActor", fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadataJson Json?
  createdAt   DateTime @default(now())
}
